{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "yaml-ls": {
      "disabled": true
    },
    "helm": {
      "command": ["helm_ls", "serve"],
      "extensions": [".yaml"]
    }
  },
  "permission": {
    "*": "ask",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow",
    "todoread": "allow"
  },
   "provider": {
    "local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Llama.cpp (local)",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1"
      },
      "models": {
        "HauhauCS/Qwen3.5-27B-Uncensored-HauhauCS-Aggressive:Q4_K_M": {
          "name": "Qwen 3.5 27B (uncensored)"
        }
      }
    }
  }
}
