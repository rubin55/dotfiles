{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "yaml-ls": {
      "disabled": true
    },
    "helm": {
      "command": [
        "helm_ls",
        "serve"
      ],
      "extensions": [
        ".yaml"
      ]
    }
  },
  "mcp": {
    "Wolfram": {
      "type": "local",
      "command": [
        "/opt/wolfram/Executables/wolfram",
        "-run",
        "PacletSymbol[\"Wolfram/AgentTools\",\"Wolfram`AgentTools`StartMCPServer\"][]",
        "-noinit",
        "-noprompt"
      ],
      "enabled": false,
      "environment": {
        "MCP_SERVER_NAME": "WolframLanguage",
        "WOLFRAM_BASE": "/opt/wolfram",
        "WOLFRAM_USERBASE": "/home/rubin/.Wolfram",
        "WOLFRAM_LOCALBASE": "/home/rubin/.Wolfram/Objects"
      }
    }
  },
  "permission": {
    "*": "ask",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow",
    "todoread": "allow"
  },
  "small_model": "openrouter/google/gemma-4-31b-it:free"
}
